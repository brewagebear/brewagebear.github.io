---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';

const allPosts = await getCollection('blog');
// 🌟 en/ 으로 시작하는 글만 가져옵니다.
const enPosts = allPosts.filter(post => post.id.startsWith('en/'));

const tags = [...new Set(enPosts.flatMap((post) => post.data.tags || []))];
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`Tags - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <Header />
        <main>
            <section>
                <h1>Tags</h1>
                <div class="tags-container">
                    {tags.map((tag) => (
                        <a href={`/en/tags/${tag}/`} class="tag-link">#{tag}</a>
                    ))}
                </div>
            </section>
        </main>
        <Footer />
    </body>
</html>