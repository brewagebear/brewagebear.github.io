---
// src/pages/en/tags/[tag].astro
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { SITE_TITLE } from '../../../consts';

export async function getStaticPaths() {
    const allPosts = await getCollection('blog');
    // 🌟 en/ 으로 시작하는 글만 필터링
    const enPosts = allPosts.filter(post => post.id.startsWith('en/'));
    
    const tags = [...new Set(enPosts.flatMap((post) => post.data.tags || []))];

    return tags.map((tag) => {
        const filteredPosts = enPosts
            .filter((post) => post.data.tags?.includes(tag))
            .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
            
        return {
            params: { tag },
            props: { posts: filteredPosts },
        };
    });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`#${tag} - ${SITE_TITLE}`} description={`Posts tagged with ${tag}`} />
    </head>
    <body>
        <Header />
        <main>
            <section>
                <h1>#{tag}</h1>
                
                <ul class="post-list">
                    {
                        posts.map((post) => {
                            // 🌟 en/ 을 제거하는 로직으로 변경
                            const cleanSlug = post.id
                                .replace(/^en\//, '')
                                .replace(/\/index\.md$/, '')
                                .replace(/\.md$/, '');
                            
                            return (
                                <li>
                                    <a href={`/en/${cleanSlug}/`}>
                                        {post.data.title}
                                    </a>
                                    <time>
                                        <FormattedDate date={post.data.date} />
                                    </time>
                                </li>
                            );
                        })
                    }
                </ul>
            </section>
        </main>
        <Footer />
    </body>
</html>